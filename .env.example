# ================================================
# ImmoVision360 - Variables d'environnement
# ================================================
# Copiez ce fichier en .env et remplissez vos valeurs.
# cp .env.example .env
#
# IMPORTANT : ne jamais commiter le fichier .env !
# ================================================

# --- PostgreSQL ---
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=immovision

# --- Google AI Studio (Gemini) ---
GEMINI_API_KEY=your_api_key_here
